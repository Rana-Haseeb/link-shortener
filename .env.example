# ── Zap ⚡ environment ──────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — your real secrets never get committed.

# 🍃 Required — MongoDB connection string (e.g. MongoDB Atlas)
MONGODB_URI=

# 🧠 Optional — OpenRouter key for AI summaries, tags & safety verdicts.
#    Without it, links are still created (just without AI metadata).
OPENROUTER_API_KEY=

# 🌐 Optional — pretty short-link domain shown in the UI (e.g. https://zap.link).
#    Falls back to the current origin (e.g. http://localhost:3000) when unset.
NEXT_PUBLIC_SHORT_DOMAIN=
