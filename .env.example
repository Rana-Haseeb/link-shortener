# ── Zap ⚡ environment ──────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — your real secrets never get committed.

# 🍃 Required — MongoDB connection string (e.g. MongoDB Atlas)
MONGODB_URI=

# 🧠 Optional — OpenRouter key for AI summaries, tags & safety verdicts.
#    Without it, links are still created (just without AI metadata).
OPENROUTER_API_KEY=
